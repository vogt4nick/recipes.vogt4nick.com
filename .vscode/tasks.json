{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build English site",
      "type": "shell",
      "command": "uv run zensical build --strict -f mkdocs.yml",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "serve English site",
      "type": "shell",
      "command": "uv run zensical serve --strict -f mkdocs.yml",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
